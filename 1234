
if not _G.__PHANTOM_RPC_HOOK_INSTALLED then
    _G.__PHANTOM_RPC_HOOK_INSTALLED = true

    -- Ждём, пока SAMP не загрузится (на случай, если скрипт стартанул рано)
    local function waitForSamp()
        while not isSampAvailable() do wait(100) end
    end
    waitForSamp()

    -- Регистрируем перехват RPC
    addEventHandler('onReceiveRpc', function(id, bs)
        if id == 93 then -- RPC_Chat
            local color = raknetBitStreamReadInt32(bs)
            local length = raknetBitStreamReadInt32(bs)
            local message = raknetBitStreamReadString(bs, length)
            -- Проверка на сообщение от Smoant_Despasito
            -- Шаблон: [ID]Имя[ID] говорит:
            if message:find('%[%d+%]Smoant_Despasito%[%d+%] говорит:') then
                sampAddChatMessage('привет', -1)
            end
        end
    end)
end
