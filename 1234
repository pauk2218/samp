        local color = raknetBitStreamReadInt32(bs)
        local len = raknetBitStreamReadInt32(bs)
        local str = raknetBitStreamReadString(bs, len)
        if str:find("%[%d+%]Smoant_Despasito%[%d+%] говорит:") then
            sampAddChatMessage('привет', -1)
        end
    end
end
